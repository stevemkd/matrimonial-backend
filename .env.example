# Production Environment Variables
# Generate a new secret key for production: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Django Settings
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,*.render.com

# Database Configuration (Render MySQL)
DB_NAME=matrimonial_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-render-mysql-host
DB_PORT=5432

# CORS Settings (for React Native app)
CORS_ALLOWED_ORIGINS=*

# Optional: For production database
# DATABASE_URL=mysql://user:password@host:port/database_name
